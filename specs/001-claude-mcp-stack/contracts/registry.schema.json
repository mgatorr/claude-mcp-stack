{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mgatorr/claude-mcp-stack/registry.schema.json",
  "title": "claude-mcp-stack registry",
  "type": "object",
  "required": ["version", "servers"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/serverEntry" }
    }
  },
  "$defs": {
    "serverEntry": {
      "type": "object",
      "required": [
        "id", "description", "category", "runtime", "package",
        "version_pin", "args_template", "secrets", "config_snippet", "healthcheck"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "description": { "type": "string", "minLength": 1 },
        "category": { "enum": ["finance", "crypto", "web", "media"] },
        "runtime": { "enum": ["uvx", "npx", "local"] },
        "package": { "type": "string", "minLength": 1 },
        "version_pin": { "type": "string", "minLength": 1 },
        "args_template": { "type": "array", "items": { "type": "string" } },
        "secrets": {
          "type": "array",
          "items": { "$ref": "#/$defs/secretDescriptor" }
        },
        "config_snippet": { "$ref": "#/$defs/configSnippet" },
        "healthcheck": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "secretDescriptor": {
      "type": "object",
      "required": ["name", "description", "where_to_get", "required"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "description": { "type": "string", "minLength": 1 },
        "where_to_get": { "type": "string", "pattern": "^https?://" },
        "required": { "type": "boolean" }
      }
    },
    "configSnippet": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
